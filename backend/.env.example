# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://localhost/cloud_cost_optimizer

# JWT secret key — use a long random string in production
JWT_SECRET=change-me

# Fernet encryption key for cloud credentials at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Anthropic API key for AI recommendations (optional)
ANTHROPIC_API_KEY=
